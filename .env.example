# ──────────────────────────────────────────────────
# X-v2 Collector — Environment Variables
# ──────────────────────────────────────────────────

# Required: credentials for the burner X/Twitter account
TWITTER_USERNAME=your_burner_username
TWITTER_PASSWORD=your_burner_password
TWITTER_EMAIL=your_burner@email.com

# Accounts to scrape (comma-separated, case-insensitive)
X_ACCOUNTS_TO_TRACK=Deltaone,financialjuice

# Redis — must be reachable from the container
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Timing controls (seconds)
POLL_INTERVAL_MIN=45
POLL_INTERVAL_MAX=55

# Failure handling
TWIKIT_FAILURE_THRESHOLD=3

# Cookie persistence
COOKIES_PATH=/app/data/cookies.json

# Health API
HEALTH_PORT=8001
HEALTH_HOST=0.0.0.0

# Logging
LOG_LEVEL=INFO
ENVIRONMENT=development
